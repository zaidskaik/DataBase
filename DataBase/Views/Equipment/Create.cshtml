@model EquipmentView //now i will work on method get to action create then i will do post

<form method="post" asp-action="Create">
    @Html.AntiForgeryToken()
    @* its mean these data which user fill it will go to method create which deal with database *@

        

    <div class="mt-3">
    <label asp-for="Name" class="col-form-label">Equipment Name</label>
    <input asp-for="Name" class="form-control" /> 
    @* form control mean he is put the type base on model either number or text *@
    <span asp-validation-for="Name" class="text-danger"></span>
    @* valdation for dont allow to input num on text feild and vise versa *@
    </div>

    <div class="mt-3">
        <label asp-for="price" class="col-form-label">Equipment Price</label>
        <input asp-for="price" class="form-control" />
        <span asp-validation-for="price" class="text-danger"></span>
    </div>

    <div class="row">
        <div class="col-auto">
            <button type="submit" class="btn btn-primary">Save</button>
        </div>
            
        <div class="col-auto">
            <button type="reset" class="btn btn-secondary">Clear</button>
        </div>
    </div>




</form>
